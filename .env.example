# --- Shared passcode ---
# Pick any passcode you want your team to use. This is the ONLY place
# it's set — there's no "first person sets it up" step anymore.
APP_PASSCODE=your-chosen-passcode

# --- Database (Supabase) ---
# From your Supabase project's Settings -> API page.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Google Sheets backup ---
# From the Google Cloud service account you create (see README.md).
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR KEY HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=the-long-id-in-your-sheets-url
