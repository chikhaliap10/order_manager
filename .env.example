# --- Shared passcode ---
APP_PASSCODE=your-chosen-passcode

# --- Database (Supabase) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# --- Google Sheets backup ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR KEY HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=the-long-id-in-your-sheets-url

# --- Scheduled sync security ---
# Any random string you make up. This confirms sync requests to
# /api/sync-sheets really came from Vercel's scheduled Cron job, not a
# random visitor to that URL. Generate one at random -- e.g. run
# `openssl rand -hex 32` in a terminal, or just mash the keyboard.
CRON_SECRET=make-up-a-long-random-string-here
