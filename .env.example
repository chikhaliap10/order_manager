# --- Database (Upstash Redis) ---
# If you add Upstash Redis through the Vercel integration marketplace,
# these are injected automatically and you can leave this file as-is.
# Only set these manually if you're running locally or connecting a
# database that wasn't added through the Vercel marketplace.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Google Sheets backup ---
# From the Google Cloud service account you create (see README.md).
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR KEY HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=the-long-id-in-your-sheets-url
